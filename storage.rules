rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /groupPhotos/{fileName} {
      allow read: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/groups/$(fileName.split('.')[0])/members/$(request.auth.uid));
      allow write: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/groups/$(fileName.split('.')[0])/members/$(request.auth.uid));
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
