# ==============================================================================
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
Thumbs.db

# Project-specific local log audits
deep_audit.txt
project_tree.txt

# ==============================================================================
# IDE & Local Workspace Configs (IntelliJ, Android Studio, VS Code)
# ==============================================================================
*.iml
*.ipr
*.iws
.idea/
.vscode/
.history/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==============================================================================
# Flutter / Dart / Pub Core
# ==============================================================================
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication & Obfuscation artifacts
app.*.symbols
app.*.map.json

# ==============================================================================
# Native Security & Secrets (Crucial for Enterprise)
# ==============================================================================
# Key assets that must NEVER be committed
*.jks
*.keystore
*.p12
*.pem
*.pkcs12
key.properties
local.properties

# Environmental variables file
.env
.env.*
.env.development
.env.production

# ==============================================================================
# Firebase Config Stripping (Preps your 6-month backend pivot)
# ==============================================================================
# Blocks current Firebase footprints from leaking into git history
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# ==============================================================================
# Platform Specific Build Outputs
# ==============================================================================
# Android artifacts
/android/app/debug
/android/app/profile
/android/app/release
/android/captures/
*.apk
*.aar
*.ap_
*.aab

# iOS / CocoaPods artifacts
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
Pods/
**/DerivedData/

# ==============================================================================
# Additional Native Secrets & Generated Config
# ==============================================================================
# iOS GoogleService config (you have one at ios/Runner/, this covers any path)
**/GoogleService-Info.plist

# Firebase options generated by flutterfire CLI — contains API keys
lib/firebase_options.dart

# iOS ephemeral Flutter config (contains local paths/build env)
**/ios/Flutter/ephemeral/

# Android signing config (if you add one)
android/key.properties

# Any service account / admin SDK credentials
*serviceAccount*.json
*-firebase-adminsdk-*.json
