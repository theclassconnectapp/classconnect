rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasCollegeClaim(collegeId) {
      return signedIn() && request.auth.token.collegeId == collegeId;
    }

    function resourceHasCollegeId(collegeId) {
      return signedIn() && resource.data.collegeId == collegeId;
    }

    function requestHasCollegeId(collegeId) {
      return signedIn() && request.resource.data.collegeId == collegeId;
    }

    function groupPath(collegeId, groupId) {
      return /databases/$(database)/documents/colleges/$(collegeId)/groups/$(groupId);
    }

    function groupHasCollegeId(collegeId, groupId) {
      return signedIn()
        && exists(groupPath(collegeId, groupId))
        && get(groupPath(collegeId, groupId)).data.collegeId == collegeId;
    }

    function canReadCollegeResource(collegeId) {
      return hasCollegeClaim(collegeId) || resourceHasCollegeId(collegeId);
    }

    function canWriteCollegeResource(collegeId) {
      return hasCollegeClaim(collegeId) || requestHasCollegeId(collegeId);
    }

    function canAccessGroupScope(collegeId, groupId) {
      return hasCollegeClaim(collegeId) || groupHasCollegeId(collegeId, groupId);
    }

    function isGroupMember(collegeId, groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/colleges/$(collegeId)/groups/$(groupId)/members/$(request.auth.uid));
    }

    match /colleges/{collegeId} {
      allow read: if signedIn();
      allow write: if false;

      match /users/{uid} {
        allow read: if signedIn()
          && request.auth.uid == uid;
        allow write: if signedIn()
          && request.auth.uid == uid
          && (hasCollegeClaim(collegeId) || requestHasCollegeId(collegeId));
      }

      match /groups/{groupId} {
        allow read: if signedIn();
        allow create: if canWriteCollegeResource(collegeId);
        allow update: if canWriteCollegeResource(collegeId)
          && request.resource.data.isGeneral == resource.data.isGeneral
          && request.resource.data.dept == resource.data.dept
          && request.resource.data.batch == resource.data.batch
          && request.resource.data.departmentId == resource.data.departmentId
          && request.resource.data.batchId == resource.data.batchId;
        allow delete: if canAccessGroupScope(collegeId, groupId)
          && resource.data.isGeneral != true
          && (
            resource.data.createdByUid == request.auth.uid
            || get(/databases/$(database)/documents/colleges/$(collegeId)/users/$(request.auth.uid)).data.role in ['hod', 'advisor']
          );

        match /members/{memberUid} {
          allow read: if signedIn();
          allow write: if signedIn() && isGroupMember(collegeId, groupId);
        }

        match /messages/{messageId} {
          allow read, write: if signedIn();
        }

        match /files/{fileId} {
          allow read, write: if signedIn();
        }

        match /states/{uid} {
          allow read, write: if signedIn()
            && request.auth.uid == uid;
        }
      }
    }

    match /users/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;

      match /aiSessions/{sessionId} {
        allow read, write: if request.auth != null
          && request.auth.uid == uid;

        match /messages/{messageId} {
          allow read, write: if request.auth != null
            && request.auth.uid == uid;
        }
      }
    }
  }
}
